-- Data Import of ER Model
CREATE TABLE `Institution` (
    `Institution_ID` varchar(100)  NOT NULL ,
    `Entity_CD` bigint  NOT NULL ,
    `Entity_Name` varchar(100)  NOT NULL ,
    PRIMARY KEY (
        `Institution_ID`
    )
);

CREATE TABLE `Subject` (
    `subject_name` varchar(100)  NOT NULL ,
    PRIMARY KEY (
        `subject_name`
    )
);

CREATE TABLE `StudentGroup` (
    `group_name` varchar(100)  NOT NULL ,
    PRIMARY KEY (
        `group_name`
    )
);

CREATE TABLE `RefusalRecord` (
    `Institution_ID` varchar(100)  NOT NULL ,
    `subject_name` varchar(100)  NOT NULL ,
    `group_name` varchar(100)  NOT NULL ,
    `TOTAL_COUNT` int  NULL ,
    `Perc_Refused` decimal(5,2)  NULL ,
    PRIMARY KEY (
        `Institution_ID`,`subject_name`,`group_name`
    )
);

ALTER TABLE `RefusalRecord` ADD CONSTRAINT `fk_RefusalRecord_Institution_ID` FOREIGN KEY(`Institution_ID`)
REFERENCES `Institution` (`Institution_ID`);

ALTER TABLE `RefusalRecord` ADD CONSTRAINT `fk_RefusalRecord_subject_name` FOREIGN KEY(`subject_name`)
REFERENCES `Subject` (`subject_name`);

ALTER TABLE `RefusalRecord` ADD CONSTRAINT `fk_RefusalRecord_group_name` FOREIGN KEY(`group_name`)
REFERENCES `StudentGroup` (`group_name`);


